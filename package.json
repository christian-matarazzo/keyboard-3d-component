{
  "name": "keyboard-composer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "asset:convert": "node --max-old-space-size=8192 node_modules/obj2gltf/bin/obj2gltf.js -i assets-src/Dither_L_Array_WEB_01.obj -o assets-src/keyboard-raw.glb",
    "asset:optimize": "gltf-transform weld assets-src/keyboard-raw.glb assets-src/kb-1.glb && gltf-transform prune assets-src/kb-1.glb assets-src/kb-2.glb --keep-attributes && gltf-transform simplify assets-src/kb-2.glb assets-src/kb-3.glb --ratio 0.25 --error 0.0005 && gltf-transform draco assets-src/kb-3.glb public/models/keyboard.glb",
    "asset:inspect": "gltf-transform inspect public/models/keyboard.glb"
  },
  "dependencies": {
    "@react-three/drei": "^10.0.0",
    "@react-three/fiber": "^9.0.0",
    "leva": "^0.10.1",
    "maath": "^0.10.8",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.178.0"
  },
  "devDependencies": {
    "@gltf-transform/cli": "^4.0.0",
    "@vitejs/plugin-react": "^4.4.0",
    "obj2gltf": "^3.1.6",
    "vite": "^6.0.0"
  }
}
